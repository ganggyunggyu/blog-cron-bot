{
  "name": "노출지기",
  "version": "1.0.0",
  "description": "네이버 검색 노출 크론 봇 (노출지기)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "pnpm test:unit",
    "test:unit": "ts-node src/cron-pages.test.ts && ts-node src/lib/dooray.test.ts && ts-node src/lib/exposure-summary.test.ts && ts-node src/lib/csv-output/csv-output.test.ts && ts-node src/lib/scheduler-runner/time.test.ts && ts-node src/lib/google-sheets/cafe-current-reexport.test.ts && ts-node src/lib/google-sheets/direct-exposure-sheet.test.ts && ts-node src/lib/google-sheets/pet-page-check.test.ts && ts-node src/lib/google-sheets/write-target-guard.test.ts && ts-node src/lib/exposure-suite/options.test.ts && ts-node src/lib/exposure-suite/run-lock.test.ts && ts-node src/lib/exposure-suite/request-broker.test.ts && ts-node src/lib/exposure-suite/recovery-delay.test.ts && ts-node src/lib/exposure-suite/settle.test.ts && ts-node src/lib/distributed-exposure/page-shards.test.ts && ts-node src/lib/distributed-exposure/worker-capacity.test.ts && ts-node src/lib/distributed-exposure/job-timeout.test.ts && ts-node src/lib/cafe-source-mirror/index.test.ts && ts-node src/lib/keyword-processor/keyword-batches.test.ts && ts-node src/lib/keyword-processor/keyword-classifier.test.ts && ts-node src/lib/keyword-processor/handlers.test.ts && ts-node src/lib/keyword-processor/shared-crawl-coordinator.test.ts && ts-node --files src/lib/keyword-processor/transient-failure.test.ts && ts-node src/lib/keyword-processor/single-page-loader.test.ts && ts-node src/lib/cafe-schedule-export/index.test.ts && ts-node src/lib/root-keyword-sync/index.test.ts && ts-node src/lib/exposure-run-config.test.ts && ts-node src/lib/playwright-crawler/block-coordinator.test.ts && ts-node src/lib/playwright-crawler/browser.test.ts && ts-node src/lib/cafe-blog-combined-result/index.test.ts && ts-node src/tools/blog-ids.test.ts && ts-node src/tools/direct-sheet-targets.test.ts && ts-node src/constants/api/index.test.ts",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "cron": "ts-node src/cron.ts",
    "cron:p": "cross-env TEST_DELAY_MINUTES=1 ts-node src/cron.ts",
    "cron:root": "cross-env FAST_EXPOSURE_MODE=true EXPOSURE_CONCURRENCY=2 ts-node src/cron-root.ts",
    "cron:dogmaru": "ts-node src/cron-dogmaru.ts",
    "cron:exclude": "ts-node src/cron-dogmaru-exclude.ts",
    "cron:pages": "ts-node src/cron-pages.ts",
    "cron:sheet": "ts-node src/cron-sheet.ts",
    "cron:pages:package": "cross-env ONLY_SHEET_TYPE=package EXPOSURE_MAX_PAGES=4 ts-node src/cron-sheet.ts",
    "cron:pages:general": "cross-env ONLY_SHEET_TYPE=dogmaru-exclude EXPOSURE_MAX_PAGES=4 ts-node src/cron-sheet.ts",
    "scheduler": "ts-node src/pm2-scheduler.ts",
    "scheduler:test": "cross-env TEST_DELAY_MINUTES=1 ts-node src/pm2-scheduler.ts",
    "scheduler:root": "ts-node src/pm2-scheduler-root.ts",
    "scheduler:root:test": "cross-env TEST_DELAY_MINUTES=1 ts-node src/pm2-scheduler-root.ts",
    "scheduler:all-sheets": "cross-env WORKFLOW_RUN_TIMES=09:00 ts-node src/pm2-scheduler-all-sheets.ts",
    "scheduler:all-sheets:test": "cross-env TEST_DELAY_MINUTES=1 WORKFLOW_RUN_TIMES=09:00 ts-node src/pm2-scheduler-all-sheets.ts",
    "naver:popular:update": "ts-node src/tools/update-popular-selectors/index.ts",
    "naver:popular:update:local": "ts-node src/tools/update-popular-selectors-local.ts",
    "migrate:rank": "ts-node src/migrations/migrate-rank/index.ts",
    "cookie:update": "ts-node src/tools/update-cookie.ts",
    "cookie:login": "ts-node src/tools/login-and-get-cookie.ts",
    "cookie:auto": "ts-node src/tools/auto-login.ts",
    "parallel:check": "ts-node src/tools/run-parallel-direct-sheet-check.ts --dry-run",
    "exposure:direct-sheet-worker": "ts-node src/tools/run-parallel-direct-sheet-check.ts",
    "exposure:cafe-current": "ts-node src/cron-cafe-current-exposure.ts",
    "exposure:suite": "ts-node src/cron-exposure-suite.ts",
    "exposure:distributed": "ts-node src/cron-distributed-exposure.ts",
    "exposure:worker": "ts-node src/exposure-worker.ts",
    "exposure:page-shard": "ts-node src/exposure-page-shard.ts",
    "exposure:package": "pnpm exposure:suite -- --targets=package",
    "exposure:general": "pnpm exposure:suite -- --targets=general",
    "exposure:dogmaru": "pnpm exposure:suite -- --targets=dogmaru",
    "exposure:root": "pnpm cron:root",
    "exposure:pet": "pnpm exposure:suite -- --targets=pet --max-pages=4",
    "exposure:pet:9-direct": "ts-node src/tools/run-parallel-direct-sheet-check.ts --target pet --concurrency 8 --max-pages 9 --skip-dooray",
    "exposure:suripet": "pnpm exposure:suite -- --targets=suripet --max-pages=4",
    "exposure:cafe": "pnpm exposure:suite -- --targets=cafe",
    "exposure:custom-cafe-0722": "ts-node src/tools/check-custom-cafe-blog-exposure.ts --tab=\"카페 노출체크 0722\"",
    "root:individual:sync": "ts-node src/tools/dry-run-root-individual-exposure.ts",
    "root:individual:dry-run": "ts-node src/tools/dry-run-root-individual-exposure.ts --dry-run",
    "keyword:report": "ts-node src/tools/keyword-report.ts",
    "cafe:check": "ts-node src/tools/check-cafe-exposure.ts",
    "cafe:check:test": "ts-node src/tools/check-cafe-exposure.test.ts",
    "cafe:schedule:check": "ts-node work/check-cafe-schedule-exposure-20260715.ts",
    "cafe:schedule:export": "ts-node work/export-cafe-schedule-exposure-20260715.ts",
    "cafe:schedule:run": "pnpm cafe:schedule:check && cross-env RETRY_FAILED_ONLY=true CHECK_CONCURRENCY=1 pnpm cafe:schedule:check && pnpm cafe:schedule:export",
    "alibaba:check": "ts-node src/tools/run-alibaba-check.ts",
    "alibaba:logic": "ts-node src/tools/check-alibaba-logic-type.ts",
    "old-logic:more-check": "ts-node src/tools/check-old-logic-more-exposure.ts",
    "old-logic:more-check:root": "cross-env EXPOSURE_PROGRESS_TARGET=root-more ts-node src/tools/check-old-logic-more-exposure.ts --sources 루트",
    "old-logic:more-check:daily": "ts-node src/tools/check-old-logic-more-exposure.ts --sources 패키지,일반건,도그마루,루트",
    "blog:share": "ts-node src/tools/blog-share-report.ts",
    "blog:share:export": "ts-node src/tools/export-blog-share-sheet.ts",
    "exposure:reexport": "ts-node src/tools/reexport-latest-ordered-results.ts",
    "exposure:reexport:current": "ts-node src/tools/reexport-current-results.ts",
    "exposure:reexport:cafe": "ts-node src/tools/reexport-current-results.ts --targets=cafe",
    "cafe-bot:published:exposure": "ts-node src/tools/check-cafe-bot-published-exposure.ts"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "chalk": "^4.1.2",
    "cheerio": "^1.2.0",
    "dotenv": "^16.0.0",
    "google-auth-library": "^10.6.1",
    "google-spreadsheet": "^5.2.0",
    "got-scraping": "^4.2.1",
    "mongoose": "^8.24.1",
    "node-cron": "^4.2.1",
    "playwright": "^1.57.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "overrides": {
      "adm-zip": "0.6.0",
      "undici": "7.28.0"
    }
  }
}
